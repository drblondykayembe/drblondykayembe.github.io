<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Content Details - drblondykayembe</title>
    <link rel="stylesheet" href="styles.css">
    <!-- PDF Viewer Library -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/pdf.js/3.11.174/pdf.min.js"></script>
    <!-- Lightbox Library -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/lightbox2/2.11.4/css/lightbox.min.css">
    <script src="https://cdnjs.cloudflare.com/ajax/libs/lightbox2/2.11.4/js/lightbox.min.js"></script>
    <!-- QR Code Library -->
    <script src="https://cdnjs.cloudflare.com/ajax/libs/qrcodejs/1.0.0/qrcode.min.js"></script>
    <!-- Dark Mode Toggle -->
    <meta name="color-scheme" content="light dark">
</head>
<body>
    <nav class="navbar">
        <div class="nav-container">
            <a href="index.html" class="logo">Dr. Blondy Kayembe</a>
            <ul class="nav-menu">
                <li><a href="index.html">Home</a></li>
                <li><a href="about.html">About</a></li>
                <li><a href="profile.html">Profile</a></li>
                <li><a href="contents.html" class="active">Contents</a></li>
                <li><a href="contact.html">Contact</a></li>
            </ul>
            <button id="dark-mode-toggle" class="dark-mode-toggle" title="Toggle dark mode">
                🌙
            </button>
        </div>
    </nav>

    <section class="page-header">
        <h1 id="page-title">Content Category</h1>
        <p class="page-subtitle" id="page-description">Loading...</p>
    </section>

    <section class="content-details-section">
        <div class="content-details-container">
            
            <!-- Controls Section -->
            <div class="content-controls">
                <div class="search-box">
                    <input 
                        type="text" 
                        id="search-input" 
                        class="search-input" 
                        placeholder="🔍 Search content..."
                    >
                    <span class="search-results-count" id="search-count"></span>
                </div>

                <div class="controls-right">
                    <div class="sort-controls">
                        <label for="sort-select">Sort by:</label>
                        <select id="sort-select" class="sort-select">
                            <option value="newest">Newest First</option>
                            <option value="oldest">Oldest First</option>
                            <option value="a-z">A - Z</option>
                            <option value="z-a">Z - A</option>
                            <option value="popular">Most Popular</option>
                            <option value="top-rated">Top Rated</option>
                        </select>
                    </div>

                    <button id="favorites-toggle" class="favorites-toggle" title="View only favorites">
                        ★ Favorites <span id="favorites-count" class="favorites-count">(0)</span>
                    </button>
                </div>
            </div>

            <!-- Filter Controls -->
            <div class="filter-controls">
                <button class="filter-btn active" data-filter="all">All</button>
                <button class="filter-btn" data-filter="pictures">Pictures</button>
                <button class="filter-btn" data-filter="videos">Videos</button>
                <button class="filter-btn" data-filter="documents">Documents</button>
                <button class="filter-btn" data-filter="articles">Articles</button>
            </div>

            <!-- Content Grid -->
            <div class="content-grid" id="content-grid">
                <!-- Content will be loaded here -->
            </div>

            <!-- No Results Message -->
            <div id="no-results-message" class="no-results-message" style="display: none;">
                <p>📭 No content found matching your criteria</p>
            </div>
        </div>
    </section>

    <!-- ===== LIGHTBOX MODAL ===== -->
    <div id="image-lightbox" class="lightbox-modal">
        <span class="lightbox-close">&times;</span>
        <img class="lightbox-content" id="lightbox-image" src="" alt="">
        <div class="lightbox-nav">
            <button class="lightbox-btn prev" id="lightbox-prev">❮</button>
            <button class="lightbox-btn next" id="lightbox-next">❯</button>
        </div>
        <div class="lightbox-info" id="lightbox-info"></div>
    </div>

    <!-- ===== PDF VIEWER MODAL ===== -->
    <div id="pdf-viewer-modal" class="modal">
        <div class="modal-content pdf-modal-content">
            <span class="close">&times;</span>
            <div class="pdf-viewer-header">
                <h2 id="pdf-title">PDF Viewer</h2>
                <div class="pdf-controls">
                    <button id="pdf-prev-page" class="pdf-btn">❮ Previous</button>
                    <div class="pdf-page-info">
                        <input type="number" id="pdf-page-input" class="pdf-page-input" value="1" min="1">
                        <span>of <span id="pdf-total-pages">0</span></span>
                    </div>
                    <button id="pdf-next-page" class="pdf-btn">Next ❯</button>
                    <button id="pdf-zoom-in" class="pdf-btn">🔍+</button>
                    <button id="pdf-zoom-out" class="pdf-btn">🔍-</button>
                    <a id="pdf-download-btn" class="pdf-btn download-btn" download>⬇️ Download</a>
                    <button id="pdf-print-btn" class="pdf-btn">🖨️ Print</button>
                </div>
            </div>
            <div class="pdf-viewer-container">
                <canvas id="pdf-canvas"></canvas>
            </div>
        </div>
    </div>

    <!-- ===== VIDEO PLAYER MODAL ===== -->
    <div id="video-modal" class="modal">
        <div class="modal-content video-modal-content">
            <span class="close">&times;</span>
            <video id="video-player" width="100%" height="600" controls>
                <source src="" type="video/mp4">
                Your browser does not support the video tag.
            </video>
            <div class="video-info">
                <h2 id="video-title"></h2>
                <a id="video-download-btn" class="btn btn-primary" download>⬇️ Download Video</a>
            </div>
        </div>
    </div>

    <!-- ===== CONTENT DETAIL VIEW MODAL ===== -->
    <div id="content-detail-modal" class="modal">
        <div class="modal-content content-detail-modal-content">
            <span class="close">&times;</span>
            
            <div class="detail-header">
                <h1 id="detail-title"></h1>
                <div class="detail-meta">
                    <span class="detail-date" id="detail-date"></span>
                    <span class="detail-type" id="detail-type"></span>
                </div>
            </div>

            <div class="detail-content">
                <!-- Rating Section -->
                <div class="rating-section">
                    <h3>Rate This Content</h3>
                    <div class="rating-display" id="rating-display">
                        <div class="stars" id="rating-stars">
                            <span class="star" data-value="1">★</span>
                            <span class="star" data-value="2">★</span>
                            <span class="star" data-value="3">★</span>
                            <span class="star" data-value="4">★</span>
                            <span class="star" data-value="5">★</span>
                        </div>
                        <span class="rating-text" id="rating-text">(0 ratings)</span>
                    </div>
                </div>

                <!-- Share Section -->
                <div class="share-section">
                    <h3>Share This Content</h3>
                    <div class="share-buttons">
                        <button class="share-btn facebook-share" title="Share on Facebook">
                            f
                        </button>
                        <button class="share-btn twitter-share" title="Share on Twitter">
                            𝕏
                        </button>
                        <button class="share-btn whatsapp-share" title="Share on WhatsApp">
                            💬
                        </button>
                        <button class="share-btn linkedin-share" title="Share on LinkedIn">
                            in
                        </button>
                        <button class="share-btn email-share" title="Share via Email">
                            ✉️
                        </button>
                        <button class="share-btn copy-link" title="Copy Link">
                            🔗
                        </button>
                    </div>
                </div>

                <!-- Comments Section -->
                <div class="comments-section">
                    <h3>Comments (<span id="comment-count">0</span>)</h3>
                    
                    <!-- Comment Form -->
                    <div class="comment-form">
                        <textarea 
                            id="comment-input" 
                            class="comment-input" 
                            placeholder="Share your thoughts..."
                            rows="4"
                        ></textarea>
                        <button id="submit-comment" class="btn btn-primary">Post Comment</button>
                    </div>

                    <!-- Comments List -->
                    <div class="comments-list" id="comments-list">
                        <!-- Comments will be loaded here -->
                    </div>
                </div>

                <!-- Action Buttons -->
                <div class="detail-actions">
                    <a id="detail-download" class="btn btn-primary" download>⬇️ Download</a>
                    <button id="detail-print" class="btn btn-secondary">🖨️ Print</button>
                </div>
            </div>
        </div>
    </div>

    <!-- ===== PRINT PREVIEW MODAL ===== -->
    <div id="print-modal" class="modal">
        <div class="modal-content print-modal-content">
            <div class="print-header">
                <h1 id="print-title"></h1>
                <button id="print-document" class="btn btn-primary">🖨️ Print Now</button>
                <span class="close">&times;</span>
            </div>
            <div class="print-preview" id="print-preview">
                <!-- Print content will be loaded here -->
            </div>
        </div>
    </div>

    <footer>
        <p>&copy; 2026 Dr. Blondy Kayembe. All rights reserved.</p>
        <div class="footer-links">
            <p><a href="https://www.facebook.com/drblondykayembe" target="_blank">Facebook</a> | 
                <a href="https://www.instagram.com/@drblondykayembe" target="_blank">Instagram</a> | 
                <a href="https://www.threads.com/@drblondykayembe" target="_blank">Threads</a> | 
                <a href="https://www.tiktok.com/@drblondykayembe" target="_blank">TikTok</a> | 
                <a href="https://www.x.com/drblondykayembe" target="_blank">X (Twitter)</a> | 
                <a href="https://www.linkedin.com/in/drblondykayembe" target="_blank">LinkedIn</a> | 
                <a href="https://www.youtube.com/@drblondykayembe" target="_blank">YouTube</a> |
                <a href="contact.html">Contact</a></p>
        </div>
    </footer>

    <!-- Scripts - Make sure these are EXTERNAL files -->
    <script src="analytics.js"></script>
    <script src="content-loader.js"></script>
</body>
</html>
